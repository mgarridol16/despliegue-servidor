# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE ENTORNO - Despliegue de Aplicaciones Web (DAW)
# ═══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env en la carpeta raíz y personaliza los valores.
#
# IMPORTANTE: NO hagas commit de .env (contiene credenciales sensibles)
#            Ya está en .gitignore
#

# ───────────────────────────────────────────────────────────────────────────────
# DOMINIO PRINCIPAL
# ───────────────────────────────────────────────────────────────────────────────
# ESTRUCTURA: <subdominio>.servidorgp.somosdelprieto.com
# Sustituye <subdominio> por tu nombre/alias (sin espacios, lowercase)
#
# Ejemplos válidos:
#   - miguel.servidorgp.somosdelprieto.com           (servidor escuela)
#   - mi-app.servidorgp.somosdelprieto.com           (servidor escuela)
#   - localhost.local                                 (desarrollo local)
#   - 192.168.1.100                                   (IP directa para pruebas)

MAIN_DOMAIN=miguel.servidorgp.somosdelprieto.com

# ───────────────────────────────────────────────────────────────────────────────
# CERTIFICADOS SSL (Let's Encrypt via ACME v2)
# ───────────────────────────────────────────────────────────────────────────────

# Email para notificaciones de Let's Encrypt (renovaciones, etc)
# Nota: El email no necesita ser real, solo RFC compliant (ASCII)
# Default si no se especifica: noreply@somosdelprieto.com
ACME_EMAIL=noreply@somosdelprieto.com

# URI del ACME server:
#   Production: https://acme-v02.api.letsencrypt.org/directory (REAL)
#   Staging:    https://acme-staging-v02.api.letsencrypt.org/directory (PRUEBAS)
# Usa Staging en desarrollo para evitar rate-limiting.
ACME_CA_URI=https://acme-v02.api.letsencrypt.org/directory

# ───────────────────────────────────────────────────────────────────────────────
# CONTRASEÑA GRAFANA (Admin)
# ───────────────────────────────────────────────────────────────────────────────
# Por defecto: admin
# Cambiar en producción por una contraseña fuerte
GRAFANA_ADMIN_PASSWORD=admin

# ───────────────────────────────────────────────────────────────────────────────
# VERSIONES DE IMÁGENES DOCKER
# ───────────────────────────────────────────────────────────────────────────────
# Formato: <imagen>:<tag>
# Dejar en blanco usa 'latest' por defecto

PROXY_VERSION=1.6
ACME_COMPANION_VERSION=latest
PORTAINER_VERSION=latest
PROMETHEUS_VERSION=latest
GRAFANA_VERSION=latest
NODE_EXPORTER_VERSION=latest

# ───────────────────────────────────────────────────────────────────────────────
# OPCIONALES: Docker Hub (solo si usas CI/CD con GitHub Actions)
# ───────────────────────────────────────────────────────────────────────────────
# NO incluyas credenciales reales en repositorio público
# Usa GitHub Secrets en .github/workflows/

# DOCKER_HUB_USERNAME=tu_usuario
# DOCKER_HUB_PASSWORD=tu_token_o_contraseña

